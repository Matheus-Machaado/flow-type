---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import CompareTable from "../components/CompareTable.astro";
import FeaturesGrid from "../components/FeaturesGrid.astro";
import ScreenshotsSection from "../components/ScreenshotsSection.astro";
import DownloadCTA from "../components/DownloadCTA.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Flow Type | sua voz vira texto onde você estiver"
  description="Dictation universal pra Windows. Segure Right Ctrl, fale, solta. Texto cola em qualquer app em menos de 1 segundo. Free, sem limite, com fallback local offline."
>
  <Header />
  <main id="main">
    <Hero />
    <HowItWorks />
    <CompareTable />
    <FeaturesGrid />
    <ScreenshotsSection />
    <DownloadCTA />
    <FAQ />
  </main>
  <Footer />
</BaseLayout>
