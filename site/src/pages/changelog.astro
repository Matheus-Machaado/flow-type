---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface ChangeGroup {
  type: "added" | "changed" | "fixed" | "refactored";
  items: string[];
}

interface Release {
  version: string;
  date?: string;
  unreleased?: boolean;
  groups: ChangeGroup[];
}

const groupLabel: Record<ChangeGroup["type"], string> = {
  added: "Adicionado",
  changed: "Mudado",
  fixed: "Corrigido",
  refactored: "Refatorado",
};

const groupColor: Record<ChangeGroup["type"], string> = {
  added: "text-success border-success/30 bg-success/10",
  changed: "text-accent border-accent/30 bg-accent/10",
  fixed: "text-warning border-warning/30 bg-warning/10",
  refactored: "text-muted border-border-strong bg-bg-2",
};

const releases: Release[] = [
  {
    version: "0.1.7",
    date: "2026-05-29",
    groups: [
      {
        type: "added",
        items: [
          "Modo travado (lock) na hotkey: dois toques rápidos em Right Ctrl (até 350 ms entre eles) travam a gravação. Qualquer toque depois encerra. Hold tradicional continua funcionando igual (push-to-talk).",
          "Cap de gravação de 60 segundos. A gravação encerra sozinha ao bater 60 s, em qualquer modo. Barra de progresso fina na base do overlay vira amber nos últimos 10 s.",
          "Indicador 'lock' no canto superior direito do overlay quando a gravação está travada.",
        ],
      },
      {
        type: "changed",
        items: [
          "Site oficial: contraste do rodapé melhorado (legível em monitores comuns).",
          "Site oficial: páginas internas de Privacidade, Termos, Licença MIT e Changelog.",
          "Copy do site e do README sem em-dash, pra leitura mais natural.",
        ],
      },
    ],
  },
  {
    version: "0.1.6",
    date: "2026-05-29",
    groups: [
      {
        type: "changed",
        items: ["UI labels do app refletem versão real (TopBar + Sobre)."],
      },
      {
        type: "refactored",
        items: [
          "Versão centralizada em site/lib/version.ts e renderer/shared/lib/app-version.ts.",
        ],
      },
      {
        type: "added",
        items: [
          "Assinatura 'Desenvolvido por Matheus Machado' no rodapé do site.",
          "Separador de título padronizado em pipe (|) em vez de em-dash, em SEO/OG.",
        ],
      },
    ],
  },
  {
    version: "0.1.5",
    groups: [
      {
        type: "fixed",
        items: [
          "Waveform do overlay reflete RMS real do microfone (zero animação cenográfica quando o mic está mudo).",
        ],
      },
    ],
  },
  {
    version: "0.1.4",
    groups: [
      {
        type: "fixed",
        items: [
          "Filtro 'App' do histórico vira chips. Selecionar 'Todos' volta sempre ao estado base.",
        ],
      },
    ],
  },
  {
    version: "0.1.3",
    groups: [
      {
        type: "changed",
        items: [
          "Biblioteca de ícones SVG outline substitui todos os emojis no app.",
        ],
      },
    ],
  },
  {
    version: "0.1.2",
    groups: [
      {
        type: "fixed",
        items: [
          "Histórico vazio quando não havia gravação.",
          "Edição só-label de slot.",
          "Limpeza do test-transcribe.",
        ],
      },
    ],
  },
  {
    version: "0.1.1",
    groups: [
      {
        type: "added",
        items: [
          "Pipeline completo: hotkey, record, STT, inject, history conectado fim-a-fim.",
        ],
      },
    ],
  },
  {
    version: "0.1.0",
    groups: [
      {
        type: "added",
        items: [
          "Release inicial. Hotkey global Right Ctrl, overlay always-on-top, transcrição via Groq Whisper Large v3 Turbo + fallback faster-whisper local, paste universal em qualquer app, histórico SQLite + FTS5, vocabulário custom.",
        ],
      },
    ],
  },
];
---

<BaseLayout
  title="Changelog | Flow Type"
  description="Histórico de versões e mudanças do Flow Type."
>
  <Header />
  <main id="main" class="max-w-3xl mx-auto px-6 py-16 sm:py-20">
    <header class="mb-10">
      <p class="text-xs font-mono text-muted uppercase tracking-wider mb-3">Docs</p>
      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">Changelog</h1>
      <p class="text-sm text-muted mt-3 max-w-xl leading-relaxed">
        Tudo que entrou e o que mudou, versão a versão. Formato baseado em
        <a
          href="https://keepachangelog.com/pt-BR/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline">Keep a Changelog</a>.
      </p>
    </header>

    <div class="space-y-12">
      {
        releases.map((r) => (
          <section
            class={`border-l-2 ${r.unreleased ? "border-accent/40" : "border-border-strong"} pl-6`}
          >
            <header class="flex flex-wrap items-baseline gap-3 mb-5">
              <h2 class="text-2xl font-semibold tracking-tight text-fg">
                {r.unreleased ? r.version : `v${r.version}`}
              </h2>
              {r.date && (
                <span class="text-xs font-mono text-muted">{r.date}</span>
              )}
              {r.unreleased && (
                <span class="text-[10px] font-mono uppercase tracking-wider text-accent bg-accent/10 border border-accent/30 px-2 py-[2px] rounded">
                  pré-release
                </span>
              )}
            </header>

            <div class="space-y-5">
              {r.groups.map((g) => (
                <div>
                  <span
                    class={`inline-block text-[10px] font-mono uppercase tracking-wider px-2 py-[2px] border rounded mb-3 ${groupColor[g.type]}`}
                  >
                    {groupLabel[g.type]}
                  </span>
                  <ul class="space-y-2 list-disc pl-5 text-sm text-fg-soft leading-relaxed">
                    {g.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
