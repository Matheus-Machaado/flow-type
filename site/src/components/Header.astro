---
import Logo from "./icons/Logo.astro";
import Icon from "./icons/Icon.astro";
---

<header class="sticky top-0 z-40 border-b border-border bg-bg-0/80 backdrop-blur supports-[backdrop-filter]:bg-bg-0/60">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Flow Type, home">
      <Logo size={28} />
      <span class="text-sm font-semibold tracking-tight">Flow Type</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-xs text-fg-soft" aria-label="Navegação principal">
      <a href="#how-it-works" class="hover:text-accent transition-colors">Como funciona</a>
      <a href="#why" class="hover:text-accent transition-colors">Por que</a>
      <a href="#features" class="hover:text-accent transition-colors">Features</a>
      <a href="#screenshots" class="hover:text-accent transition-colors">Screenshots</a>
      <a href="#faq" class="hover:text-accent transition-colors">FAQ</a>
      <a
        href="https://github.com/flowtypeapp/flowtype"
        rel="noopener noreferrer"
        target="_blank"
        class="hover:text-accent transition-colors inline-flex items-center gap-1"
      >
        GitHub
        <Icon name="external" size={12} />
      </a>
    </nav>

    <a
      href="#download"
      class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-accent text-bg-0 hover:bg-accent-2 transition-colors shadow-glow inline-flex items-center gap-1.5"
    >
      <Icon name="download" size={14} />
      Baixar .exe
    </a>
  </div>
</header>
